    type = "xml"
  }

  column "dita_type" {
    type = "text"
  }

  column "xml_declaration" {
    type = "text"
  }

  column "content" {
    type = "jsonb"
  }

  column "metadata" {
    type = "jsonb"
  }

  column "internal_reference" {
    type = "text"
  }

  column "source_uri" {
    type = "text"
  }

  column "is_current" {
    type = "boolean"
    default = "true"
  }

  column "version_number" {
    type = "integer"
    default = "1"
  }

  column "root_resource_id" {
    type = "uuid"
    null = false
  }

  column "publishing_status" {
    type = "text"
    null = false
    default = "'DRAFT'::text"
  }

  column "published_at" {
    type = "timestamp with time zone"
  }

  column "retired_at" {
    type = "timestamp with time zone"
  }

  column "archived_at" {
    type = "timestamp with time zone"
  }

  column "created_by" {
    type = "uuid"
    null = false
  }

  column "updated_by" {
    type = "uuid"
  }

  column "created_at" {
    type = "timestamp with time zone"
    default = "CURRENT_TIMESTAMP"
  }

  column "updated_at" {
    type = "timestamp with time zone"
    default = "CURRENT_TIMESTAMP"
  }

  column "content_scope" {
    type = "text"
    null = false
    default = "'independent'::text"
  }

  column "interaction_type" {
    type = "text"
  }

  column "search_vector" {
    type = "tsvector"
    default = "(((setweight(to_tsvector('english'::regconfig, COALESCE(name, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(title, ''::text)), 'A'::\"char\")) || setweight(to_tsvector('english'::regconfig, ((COALESCE(replace(interaction_type, '-'::text, ' '::text), ''::text) || ' '::text) || extract_search_text(type, COALESCE(content, '{}'::jsonb)))), 'B'::\"char\")) || setweight(to_tsvector('english'::regconfig, COALESCE((metadata)::text, ''::text)), 'C'::\"char\"))"
  }

  primary_key {
    columns = ["id"]
  }

  foreign_key "resources_created_by_foreign" {
    columns     = ["created_by"]
    ref_table   = "users"
    ref_columns = ["id"]
  }

  foreign_key "resources_portfolio_id_foreign" {
    columns     = ["portfolio_id"]
    ref_table   = "portfolios"
    ref_columns = ["id"]
    on_delete   = "set_null"
  }

  foreign_key "resources_root_resource_fk" {
    columns     = ["root_resource_id"]
    ref_table   = "resources"
    ref_columns = ["id"]
    on_delete   = "cascade"
  }

  foreign_key "resources_updated_by_foreign" {
    columns     = ["updated_by"]
    ref_table   = "users"
    ref_columns = ["id"]
  }

  index "idx_one_draft_per_root" {
    columns = ["root_resource_id"]
    unique  = true
  }

  index "idx_one_live_per_root" {
    columns = ["root_resource_id"]
    unique  = true
  }

  index "idx_res_content_scope" {
    columns = ["content_scope"]
  }

  index "idx_res_fts" {
    columns = ["search_vector"]
  }

  index "idx_res_hash" {
