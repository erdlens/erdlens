table "activity_feed_reads" {

  column "user_id" {
    type = "uuid"
    null = false
  }

  column "audit_log_id" {
    type = "bigint"
    null = false
  }

  column "read_at" {
    type = "timestamp with time zone"
    default = "CURRENT_TIMESTAMP"
  }

  primary_key {
    columns = ["user_id", "audit_log_id"]
  }

  foreign_key "activity_feed_reads_audit_log_id_foreign" {
    columns     = ["audit_log_id"]
    ref_table   = "audit_log"
    ref_columns = ["id"]
    on_delete   = "cascade"
  }

  foreign_key "activity_feed_reads_user_id_foreign" {
    columns     = ["user_id"]
    ref_table   = "users"
    ref_columns = ["id"]
    on_delete   = "cascade"
  }

  index "idx_afr_user" {
    columns = ["user_id", "read_at"]
  }

  layout {
    x = 1840
    y = 236
  }
}

